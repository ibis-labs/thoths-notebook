Phase 3 — OpenClaw Listener Script (runs on the Dell)
A Node.js script (firestore-bridge.js) living in the OpenClaw project, using firebase-admin
SDK with a service account key:
const admin = require('firebase-admin');
const serviceAccount = require('./serviceAccountKey.json');

admin.initializeApp({
  credential: admin.credential.cert(serviceAccount)
});

const db = admin.firestore();

// Watch for new pending commands
db.collection('agent_commands')
  .where('status', '==', 'pending')
  .onSnapshot(async (snapshot) => {
    for (const change of snapshot.docChanges()) {
      if (change.type !== 'added') continue;

      const ref = change.doc.ref;
      const { instruction, model } = change.doc.data();

      // Claim the command immediately
      await ref.update({ status: 'running' });

      try {
        // Submit to OpenClaw Gateway (interface TBD — see Open Questions)
        const result = await openClawGateway.submit({ instruction, model });

        await ref.update({
          status: 'complete',
          result,
          completedAt: admin.firestore.FieldValue.serverTimestamp()
        });
      } catch (err) {
        await ref.update({
          status: 'error',
          result: err.message
        });
      }
    }
  });

