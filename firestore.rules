rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. TASKS: Only the owner can see or edit their tasks
    match /tasks/{taskId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 2. DAILY RITUALS: Only the owner can see or edit their rituals
    match /dailyRituals/{ritualId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 3. USERS: Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. CHRONICLES: The new Evening Chronicle entries (ADDED THIS)
    match /chronicles/{chronicleId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 5. OSTRACA COLLECTIONS: Owner-only access
    match /ostracaCollections/{collectionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 6. OSTRACA TILES: Owner-only access
    match /ostracaTiles/{tileId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 7. IPHTY INVITATIONS: One-time codes for opening encrypted channels
    match /iphtyInvitations/{code} {
      // Only the invitor may create their own invitation.
      allow create: if request.auth != null
        && request.resource.data.invitorId == request.auth.uid;

      // get (by known code ID) — any authenticated user, to redeem.
      // list — owner only; prevents harvesting the entire collection.
      allow get: if request.auth != null;
      allow list: if request.auth != null
        && resource.data.invitorId == request.auth.uid;

      // Invitor may cancel: may only set status → 'cancelled', no other fields.
      allow update: if request.auth != null
        && resource.data.invitorId == request.auth.uid
        && request.resource.data.status == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // Redeemer may mark used: must not be the invitor, doc must be pending,
      // and only the redemption fields may be written.
      allow update: if request.auth != null
        && request.auth.uid != resource.data.invitorId
        && resource.data.status == 'pending'
        && request.resource.data.status == 'used'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'redeemedBy', 'redeemedAt'])
        && request.resource.data.redeemedBy == request.auth.uid;

      // Only the invitor may delete their own invitation.
      allow delete: if request.auth != null
        && resource.data.invitorId == request.auth.uid;
    }

    // 8. IPHTY LINKS: Encrypted scribe-to-scribe channels (created via invitation code)
    match /iphtyLinks/{linkId} {
      // Links are created by the code redeemer (requesteeId == auth.uid)
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // Both participants can read
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Both participants can update
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Both participants can delete
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // 8a. MESSAGES sub-collection: active-link participants only
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/iphtyLinks/$(linkId)).data.participants
          && get(/databases/$(database)/documents/iphtyLinks/$(linkId)).data.status == 'active';

        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/iphtyLinks/$(linkId)).data.participants
          && get(/databases/$(database)/documents/iphtyLinks/$(linkId)).data.status == 'active'
          && request.resource.data.senderId == request.auth.uid;
      }
    }
    
  }
}